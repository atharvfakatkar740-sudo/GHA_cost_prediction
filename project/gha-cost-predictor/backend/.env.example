# ─── Database (PostgreSQL) ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gha_cost_predictor

# ─── GitHub ──────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your_personal_access_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ─── ML Model ────────────────────────────────────────────────────────
MODEL_PATH=./ml_models/model.joblib

# ─── Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Pricing cache TTL in seconds (default 1 hour) ──────────────────
PRICING_CACHE_TTL=3600

# ─── JWT Auth ────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_RESET_TOKEN_EXPIRE_MINUTES=30

# ─── SMTP (Google SMTP for password reset) ───────────────────────────
# 1. Enable 2-Step Verification on your Google Account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-char app password below (not your Google login password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM_NAME=GHA Cost Predictor
SMTP_FROM_EMAIL=your_email@gmail.com
