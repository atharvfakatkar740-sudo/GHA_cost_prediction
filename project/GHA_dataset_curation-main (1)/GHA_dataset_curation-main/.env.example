# ============================================================
#  GitHub Workflow Dataset Collector — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ------------------------------------------------------------------
# GitHub Personal Access Tokens  (REQUIRED — at least one)
# ------------------------------------------------------------------
# Create free tokens at: https://github.com/settings/tokens
# Click "Generate new token (classic)"
# No special scopes are needed for public repos — just leave all
# checkboxes unchecked.
#
# The more tokens you add, the less likely you are to hit rate limits.
# Tokens rotate in round-robin order automatically.

GITHUB_TOKEN=ghp_YourFirstTokenHere
GITHUB_TOKEN_2=ghp_YourSecondTokenHere
GITHUB_TOKEN_3=ghp_YourThirdTokenHere

# Add up to GITHUB_TOKEN_20 if you have that many.

# ------------------------------------------------------------------
# Output paths  (optional — defaults shown)
# ------------------------------------------------------------------
OUTPUT_CSV=output/workflow_features.csv
CHECKPOINT_FILE=output/checkpoint.json
LOG_FILE=output/collector.log

# ------------------------------------------------------------------
# Pipeline tuning  (optional — defaults shown)
# ------------------------------------------------------------------

# Parallel repo-processing threads.
# Keep ≤ number of tokens to avoid hammering a single token.
MAX_WORKERS=4

# Workflow runs to collect per workflow YAML file per repo.
# 30 × ~5 workflows/repo = 150 rows/repo on average.
MAX_RUNS_PER_WORKFLOW=5

# Hard cap on total rows per repo across ALL its workflow files.
# Prevents a repo with 20 workflow files dominating the dataset.
# Set to 0 to disable.
MAX_ROWS_PER_REPO=25

# Repos returned per GitHub Search query.
# GitHub caps this at 1000 total, 100 per page.
MAX_REPOS_PER_QUERY=50

# Set to "true" to skip code-complexity analysis.
# Saves ~20 API calls per repo; sets code_complexity=0.05 for all rows.
SKIP_COMPLEXITY=false

# HTTP request timeout in seconds.
REQUEST_TIMEOUT=30

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
